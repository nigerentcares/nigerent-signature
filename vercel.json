{
  "framework": "nextjs",
  "buildCommand": "prisma generate && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_SUPABASE_URL": "@nigerent_supabase_url",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "@nigerent_supabase_anon_key",
    "SUPABASE_SERVICE_ROLE_KEY": "@nigerent_service_role_key",
    "DATABASE_URL": "@nigerent_database_url",
    "DIRECT_URL": "@nigerent_direct_url",
    "NEXT_PUBLIC_APP_URL": "@nigerent_app_url",
    "NEXTAUTH_SECRET": "@nigerent_nextauth_secret"
  },
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",    "value": "nosniff" },
        { "key": "X-Frame-Options",           "value": "DENY" },
        { "key": "Referrer-Policy",           "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
